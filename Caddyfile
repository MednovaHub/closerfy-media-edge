# Closerfy Media Edge — Caddy reverse proxy
# Termina TLS (Let's Encrypt automático) e proxa pra Janus internamente.
# {$MEDIA_HOSTNAME} vem da env (ex: media.closerfy.ai)

{$MEDIA_HOSTNAME} {
	# Janus REST API (sessions, plugins, ICE handling)
	# Usa `handle` (não `handle_path`) pra PRESERVAR o /janus prefix —
	# o Janus espera receber /janus/info, /janus/<sessionId>, etc.
	# handle_path removia o prefix e Janus respondia 404.
	handle /janus* {
		reverse_proxy 127.0.0.1:8088
	}

	# Admin API (stop recording, get info)
	# Protegido por admin_secret no janus.jcfg + admin_acl=127.0.0.1.
	handle /admin* {
		reverse_proxy 127.0.0.1:7088
	}

	# Asterisk ARI — REST + WebSocket events
	# Backend Closerfy autentica via Basic Auth (closerfy:ASTERISK_ARI_PASSWORD).
	handle /ari* {
		reverse_proxy 127.0.0.1:8090
	}

	# Asterisk PJSIP WebSocket transport (browser SIP.js / JsSIP)
	# Path /ws é fixo no Asterisk (não customizável via prefix).
	handle /ws {
		reverse_proxy 127.0.0.1:8090
	}

	# Health endpoint pro UptimeRobot ou similar
	handle /health {
		respond "ok" 200
	}

	# Default: rejeita
	handle {
		respond "Not Found" 404
	}

	# Logs estruturados
	log {
		output stdout
		format json
	}

	# Headers de segurança
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
	}
}
