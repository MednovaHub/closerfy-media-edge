# Closerfy Media Edge — env vars
# Copia esse arquivo pra `.env` (mesmo dir) e preenche.
# `.env` é gitignored — NUNCA commitar.

# ─── Domínio público da VPS ──────────────────────────────────────────
# Apontar registro A no DNS pra IP da VPS antes de subir o stack.
MEDIA_HOSTNAME=media.closerfy.ai

# ─── Janus admin secret ──────────────────────────────────────────────
# Gera com: openssl rand -hex 32
# Esse secret protege /admin endpoint do Janus + é usado pelo backend
# Closerfy (env JANUS_ADMIN_SECRET) pra criar/destruir sessões.
JANUS_ADMIN_SECRET=

# ─── Coturn shared secret ────────────────────────────────────────────
# Gera com: openssl rand -hex 32
# Usado pra autenticar credenciais TURN time-limited.
COTURN_SHARED_SECRET=

# ─── Backend Closerfy ────────────────────────────────────────────────
# URL base + token pro recorder-watcher POSTar gravações finalizadas.
CLOSERFY_BACKEND_URL=https://api.closerfy.ai
CLOSERFY_INGEST_TOKEN=

# ─── IPs externos da VPS (descobrir com: curl ifconfig.me) ──────────
# Coturn precisa saber o IP público pra advertise nas candidatas ICE.
PUBLIC_IP=
